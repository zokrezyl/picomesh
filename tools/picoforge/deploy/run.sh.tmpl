#!/bin/sh
# picomesh deploy launcher — HOST convenience entry point.
#
# Layout next to this script (the deploy / payload root):
#   ./picomesh             picomesh binary (host-arch here, riscv64 in the VM)
#   ./picoforge-webapp     browser-facing HTML page tier
#   ./picoforge.yaml       mesh services config (collocated all-in-one)
#   ./frontend/static/     CSS + html + js the webapp serves
#   ./service/             runit run-scripts (the single source of truth for
#                          how each service is launched):
#       common.sh            shared env + helpers
#       mesh/run             the picomesh node (gateway + all backends)
#       webapp/run           the picoforge web app
#       probe/run            availability checker (1s loop, prints to stdout)
#   ./init                 PID-1 init used INSIDE the VM (mounts/net/tmpfs +
#                          `exec runsvdir /etc/service`); unused on the host
#   ./run.sh               this file
#
# Inside the riscv64 VM the kernel boots `init=/opt/picoforge/init`, which
# brings the system up and hands the three services to runit. This run.sh is
# NOT used in the VM — it exists so a developer can exercise the exact same
# service scripts on the host:  cd build-deploy && ./run.sh
#
# It launches the three service run-scripts as background children (each one
# `exec`s its daemon / loop) and waits, tearing them down on Ctrl-C.

set -u

HERE=$(cd "$(dirname "$0")" 2>/dev/null && pwd)
[ -n "${HERE}" ] || HERE=$(pwd)
cd "${HERE}"

export PF_ROOT="${HERE}"
. "${HERE}/service/common.sh"

say run "PID=$$ host launcher start (PF_ROOT=${PF_ROOT})"

# mesh first; webapp + probe wait for / poll the gateway on their own.
sh "${HERE}/service/mesh/run" &
MESH_PID=$!
say run "mesh service pid=${MESH_PID}"

sh "${HERE}/service/webapp/run" &
WEBAPP_PID=$!
say run "webapp service pid=${WEBAPP_PID}"

sh "${HERE}/service/probe/run" &
PROBE_PID=$!
say run "probe service pid=${PROBE_PID}"

# Ctrl-C tears the whole group down. We started these children, so killing
# the specific PIDs we captured is correct here (host-only path).
trap 'say run "shutting down"; kill ${MESH_PID} ${WEBAPP_PID} ${PROBE_PID} 2>/dev/null; exit 0' INT TERM

# Block on the mesh node; if it exits, bring the others down too.
wait ${MESH_PID}
say run "mesh node exited rc=$? — stopping webapp + probe"
kill ${WEBAPP_PID} ${PROBE_PID} 2>/dev/null
